{
    "name": "companion-module-prinsvision-server",
    "version": "2.0.2",
    "description": "Bitfocus Companion module for PrinsVision color grading system",
    "main": "dist/main.js",
    "type": "module",
    "license": "MIT",
    "author": "Prins Vision",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bitfocus/companion-module-prinsvision-server.git"
    },
    "bugs": {
        "url": "https://github.com/bitfocus/companion-module-prinsvision-server/issues"
    },
    "homepage": "https://github.com/bitfocus/companion-module-prinsvision-server#readme",
    "keywords": [
        "companion-module"
    ],
    "engines": {
        "node": "^22.20"
    },
    "packageManager": "yarn@4.17.0",
    "scripts": {
        "build": "node scripts/sync-version.mjs && tsc -p tsconfig.json",
        "build:watch": "tsc -p tsconfig.json --watch",
        "package": "yarn build && companion-module-build --output prinsvision-server-module",
        "sync-version": "node scripts/sync-version.mjs"
    },
    "dependencies": {
        "@companion-module/base": "~2.0.4",
        "socket.io-client": "^4.7.0"
    },
    "devDependencies": {
        "@companion-module/tools": "^3.0.2",
        "@types/node": "^20.0.0",
        "typescript": "^5.3.0"
    },
    "overrides": {
        "ws": "^8.21.0"
    }
}
